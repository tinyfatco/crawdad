{
	"name": "@tinyfatco/troublemaker",
	"version": "0.1.0",
	"description": "Mom, liberated. Multi-platform AI agent runtime.",
	"type": "module",
	"bin": {
		"troublemaker": "dist/main.js",
		"crawdad": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"CHANGELOG.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"patch": "node scripts/patch-agent-loop.js",
		"typecheck": "tsc --noEmit",
		"build": "npm run patch && tsc && chmod +x dist/main.js",
		"dev": "tsc --watch --preserveWatchOutput",
		"test:awareness-stream": "npx tsx test/awareness-stream.test.ts",
		"validate:local": "npm run typecheck && npm run build && npm run test:awareness-stream",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@anthropic-ai/sandbox-runtime": "0.0.16",
		"@mariozechner/pi-agent-core": "0.64.0",
		"@mariozechner/pi-ai": "0.64.0",
		"@mariozechner/pi-coding-agent": "0.64.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@mozilla/readability": "0.6.0",
		"@sinclair/typebox": "0.34.48",
		"@slack/socket-mode": "2.0.5",
		"@slack/web-api": "7.14.1",
		"chalk": "5.6.2",
		"croner": "9.1.0",
		"diff": "8.0.3",
		"jsdom": "27.4.0",
		"node-pty": "1.1.0",
		"node-telegram-bot-api": "0.66.0",
		"turndown": "7.2.2",
		"turndown-plugin-gfm": "1.0.2",
		"ws": "8.19.0",
		"zod": "^3.25.76"
	},
	"overrides": {
		"axios": "1.13.5"
	},
	"devDependencies": {
		"@types/diff": "7.0.2",
		"@types/jsdom": "28.0.1",
		"@types/node": "24.10.13",
		"@types/node-telegram-bot-api": "0.64.13",
		"@types/turndown": "5.0.6",
		"@types/ws": "8.18.1",
		"typescript": "5.9.3"
	},
	"keywords": [
		"slack",
		"telegram",
		"bot",
		"ai",
		"agent",
		"troublemaker"
	],
	"author": "TinyFat Co",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tinyfatco/troublemaker.git"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
